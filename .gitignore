# MarkScientist .gitignore

# Environment
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Trajectory data (keep structure, ignore content)
data/trajectories/*
!data/trajectories/.gitkeep

# Temporary files
*.log
*.tmp
.DS_Store
Thumbs.db

# Model files (v1.0)
models/*.bin
models/*.pt
models/*.safetensors
adapters/
