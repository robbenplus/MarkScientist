# MarkScientist Environment Configuration

# =============================================================================
# API Configuration
# =============================================================================

# OpenAI Compatible API
API_BASE=https://api.openai.com/v1
API_KEY=your-api-key-here

# Model Selection
MODEL_BACKEND=openai  # openai | anthropic
MODEL_NAME=gpt-4o
# MODEL_NAME=claude-3-opus-20240229

# For Anthropic (if using anthropic backend)
# ANTHROPIC_API_KEY=your-anthropic-key

# =============================================================================
# Agent Configuration
# =============================================================================

# Default agent type: solver | judge | evaluator
DEFAULT_AGENT=solver

# LLM call limits
MAX_LLM_CALL_PER_RUN=100
MAX_AGENT_RUNTIME_SECONDS=9000
LLM_MAX_OUTPUT_TOKENS=10000
MAX_INPUT_TOKENS=320000

# Temperature settings
TEMPERATURE=0.6
TOP_P=0.95
PRESENCE_PENALTY=1.1

# =============================================================================
# Trajectory Configuration
# =============================================================================

# Auto-save trajectories
TRAJECTORY_AUTO_SAVE=true
TRAJECTORY_DIR=./data/trajectories

# =============================================================================
# Workspace Configuration
# =============================================================================

# Default workspace root (optional)
# WORKSPACE_ROOT=/path/to/workspace

# =============================================================================
# Debug
# =============================================================================

# Enable debug output
# DEBUG_AGENT=true
